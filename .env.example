# Example environment variables for Rust Store
# SQLite local database
DATABASE_URL="file:./dev.db"

# Auth configuration
# Set AUTH_MODE to "steam" to enable Steam OpenID (requires STEAM_API_KEY)
AUTH_MODE="mock"
#STEAM_API_KEY=

# Secret for signing session JWTs - change in production
NEXTAUTH_SECRET="change-me-in-production"

# Public site URL (used for redirects)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
